                                         irqs, env->miprio);
     }
 
+    /* WS63 custom local interrupts (IRQ >= 32), gated by M-mode enable. */
+    if (mie && !env->virt_enabled) {
+        int ws63_irq = ws63_local_irq_pending(env);
+        if (ws63_irq != RISCV_EXCP_NONE) {
+            return ws63_irq;
+        }
+    }
+
     /* Check for virtual S-mode interrupts. */
     irqs_f = env->mvip & (env->mvien & ~env->mideleg) & env->sie;
 
